---
import BaseLayout from "../layouts/BaseLayout.astro";
import Badge from "../components/ui/Badge.astro";
import ButtonLink from "../components/ui/ButtonLink.astro";
import Card from "../components/ui/Card.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";

const impactAreas = [
  {
    title: "User safety and reporting flows",
    text: "Contributed to frontend work around user safety and reporting experiences, including UI changes, accessibility considerations, coordination with service/security/privacy stakeholders, and rollout awareness.",
  },
  {
    title: "Code quality and maintainability",
    text: "Improved maintainability through cleanup of obsolete code, naming improvements, documentation, and safer rollout practices.",
  },
  {
    title: "Team process and collaboration",
    text: "Supported delivery and communication in a distributed team environment, including Scrum Master responsibilities between 2021 and 2024.",
  },
];

const strengths = [
  {
    title: "Frontend",
    items: ["React", "TypeScript", "JavaScript", "HTML", "CSS", "Tailwind CSS"],
  },
  {
    title: "Product UI",
    items: [
      "forms",
      "state",
      "async flows",
      "design systems",
      "accessibility",
      "responsive interfaces",
    ],
  },
  {
    title: "Testing",
    items: [
      "Vitest",
      "Testing Library",
      "unit tests",
      "component tests",
      "behavior-focused tests",
    ],
  },
  {
    title: "Architecture",
    items: [
      "feature-based structure",
      "typed domain models",
      "API boundaries",
      "documentation",
      "maintainability",
    ],
  },
  {
    title: "Tools",
    items: ["GitHub", "Copilot", "ChatGPT", "Claude", "Figma", "Supabase"],
  },
];

const workSignals = [
  "user-facing frontend engineering",
  "large-scale product environments",
  "distributed team collaboration",
  "quality and maintainability improvements",
  "accessibility-aware UI work",
  "security and privacy-aware product flows",
  "clear documentation",
  "iterative delivery",
];
---

<BaseLayout
  title="Experience — Ewa Ramus"
  description="Professional experience of Ewa Ramus, a React and TypeScript frontend engineer focused on product quality, accessibility, maintainability, and user-facing software."
>
  <section class="section-spacing mx-auto max-w-7xl px-6 md:px-8">
    <div class="grid gap-10 lg:grid-cols-[1fr_0.75fr] lg:items-start">
      <div>
        <Badge tone="warm">Experience</Badge>

        <h1 class="mt-6 max-w-4xl text-text-[clamp(2.75rem,14vw,4.5rem)] font-bold leading-[0.98] tracking-[-0.055em][clamp(2.75rem,14vw,4.5rem)] font-bold leading-[0.98] tracking-[-0.055em]">
          Large-scale product work, frontend quality, and continuous improvement.
        </h1>

        <p class="mt-7 max-w-3xl text-xl leading-[1.8] text-[var(--text-secondary)]">
          My professional experience is centered around React + TypeScript frontend engineering,
          user-facing product work, quality improvements, accessibility, and collaboration in
          distributed teams.
        </p>
      </div>

      <Card>
        <p class="font-mono-label text-[12px] uppercase tracking-[0.18em] text-[var(--text-muted)]">
          Current role
        </p>

        <h2 class="mt-4 text-2xl font-semibold tracking-[-0.04em] text-[var(--text-primary)]">
          Software Engineer II — Microsoft
        </h2>

        <p class="font-mono-label mt-3 text-[11px] uppercase tracking-[0.18em] text-[var(--accent-warm)]">
          Jan 2021 – Present
        </p>

        <p class="mt-4 text-base leading-[1.8] text-[var(--text-secondary)]">
          Skype / Microsoft Teams
        </p>

        <div class="mt-7 flex flex-wrap gap-2">
          <Badge tone="blue">React</Badge>
          <Badge tone="blue">TypeScript</Badge>
          <Badge tone="default">Product UI</Badge>
          <Badge tone="default">Accessibility</Badge>
          <Badge tone="success">Quality</Badge>
        </div>
      </Card>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 pb-24 md:px-8 md:pb-32">
    <Card>
      <div class="grid gap-8 md:grid-cols-[0.8fr_1.2fr] md:items-center">
        <div>
          <Badge tone="blue">Microsoft</Badge>

          <h2 class="mt-5 text-3xl font-semibold leading-tight tracking-[-0.04em] text-[var(--text-primary)] md:text-4xl">
            Frontend work in communication products used at scale.
          </h2>
        </div>

        <div>
          <p class="text-base leading-[1.8] text-[var(--text-secondary)] md:text-lg">
            I work on frontend experiences in large-scale communication products, contributing to
            user-facing features, platform improvements, quality initiatives, accessibility
            improvements, and cross-functional delivery.
          </p>

          <div class="mt-7 flex flex-wrap gap-2">
            {
              workSignals.map((signal) => (
                <Badge tone="default">
                  {signal}
                </Badge>
              ))
            }
          </div>
        </div>
      </div>
    </Card>
  </section>

  <section class="mx-auto max-w-7xl px-6 pb-24 md:px-8 md:pb-32">
    <SectionHeading
      eyebrow="Selected impact areas"
      title="The work I’m most proud of is usually the work that makes products safer, clearer, and easier to maintain."
      text="I care about the kind of frontend work that quietly improves product trust: better flows, better states, better structure, better documentation, and fewer fragile edges."
    />

    <div class="grid gap-5 lg:grid-cols-3">
      {
        impactAreas.map((area) => (
          <Card interactive>
            <h3 class="text-xl font-semibold text-[var(--text-primary)]">
              {area.title}
            </h3>

            <p class="mt-4 text-base leading-[1.8] text-[var(--text-secondary)]">
              {area.text}
            </p>
          </Card>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 pb-24 md:px-8 md:pb-32">
    <SectionHeading
      eyebrow="Technical strengths"
      title="React + TypeScript, with product behavior in mind."
      text="My strongest area is frontend engineering for user-facing products: typed components, stateful flows, accessible UI, testing, maintainability, and clear collaboration."
    />

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        strengths.map((group) => (
          <Card>
            <h3 class="text-xl font-semibold text-[var(--text-primary)]">
              {group.title}
            </h3>

            <div class="mt-6 flex flex-wrap gap-2">
              {
                group.items.map((item) => (
                  <Badge tone="default">
                    {item}
                  </Badge>
                ))
              }
            </div>
          </Card>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 pb-24 md:px-8 md:pb-32">
    <Card>
      <div class="grid gap-8 md:grid-cols-[0.85fr_1.15fr] md:items-center">
        <div>
          <Badge tone="warm">Working style</Badge>

          <h2 class="mt-5 text-3xl font-semibold leading-tight tracking-[-0.04em] text-[var(--text-primary)] md:text-4xl">
            I like teams where quality is part of product work.
          </h2>
        </div>

        <div>
          <p class="text-base leading-[1.8] text-[var(--text-secondary)] md:text-lg">
            I enjoy teams where engineers care about users, communicate clearly, improve systems
            over time, and treat quality as part of product work rather than a separate afterthought.
          </p>

          <p class="mt-5 text-base leading-[1.8] text-[var(--text-secondary)] md:text-lg">
            I value honest technical communication, async-friendly documentation, thoughtful trade-offs,
            and steady iteration over noisy heroics.
          </p>

          <div class="mt-7 flex flex-wrap gap-3">
            <ButtonLink href="/projects" variant="primary">
              View projects
            </ButtonLink>

            <ButtonLink href="/about" variant="secondary">
              Read about how I work
            </ButtonLink>
          </div>
        </div>
      </div>
    </Card>
  </section>
</BaseLayout>