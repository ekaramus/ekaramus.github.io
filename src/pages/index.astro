---
import BaseLayout from "../layouts/BaseLayout.astro";
import Badge from "../components/ui/Badge.astro";
import ButtonLink from "../components/ui/ButtonLink.astro";
import Card from "../components/ui/Card.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import ProjectCard from "../components/projects/ProjectCard.astro";
import { projects } from "../data/projects";
---

<BaseLayout>
  <section class="section-spacing mx-auto max-w-7xl px-5 md:px-8">
    <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div>
        <Badge tone="warm">Product Engineering · UI Systems · Craft</Badge>

        <h1 class="mt-6 max-w-4xl text-5xl font-bold leading-[0.95] tracking-[-0.06em] text-[var(--text-primary)] md:text-7xl">
          I build thoughtful interfaces and quietly obsess over how they work.
        </h1>

        <p class="mt-7 max-w-3xl text-lg leading-[1.8] text-[var(--text-secondary)]">
          I’m Ewa — a React + TypeScript engineer with Microsoft experience across Skype and Teams.
          I enjoy building products where frontend architecture, UX clarity, accessibility, performance,
          and product thinking support each other. I care deeply about iteration, quality,
          maintainability, and the small details users feel even when they don’t notice them directly.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <ButtonLink href="/projects" variant="primary">
            Explore projects
          </ButtonLink>

          <ButtonLink href="https://github.com/ekaramus" external>
            GitHub
          </ButtonLink>
        </div>

        <p class="font-mono-label mt-6 text-[11px] uppercase tracking-[0.18em] text-[var(--text-muted)]">
          React · TypeScript · UI/UX · Testing · Accessibility · Security-minded engineering
        </p>
      </div>

      <Card>
        <p class="font-mono-label text-[12px] uppercase tracking-[0.18em] text-[var(--text-muted)]">
          Current build
        </p>

        <h2 class="mt-4 text-3xl font-semibold tracking-[-0.04em] text-[var(--text-primary)]">
          VoicePin
        </h2>

        <p class="mt-4 text-base leading-[1.8] text-[var(--text-secondary)]">
          Short voice snapshots, automatic transcription, and a retro recording flow focused on
          communication that feels lightweight, human, and intentional.
        </p>

        <div class="mt-6 space-y-3">
          <div class="flex items-center justify-between gap-4 border-b border-[var(--border-primary)] pb-3">
            <span class="font-mono-label text-[11px] uppercase tracking-[0.18em] text-[var(--text-muted)]">
              voice_recording_flow
            </span>
            <Badge tone="success">stable</Badge>
          </div>

          <div class="flex items-center justify-between gap-4 border-b border-[var(--border-primary)] pb-3">
            <span class="font-mono-label text-[11px] uppercase tracking-[0.18em] text-[var(--text-muted)]">
              speech_to_text_pipeline
            </span>
            <Badge tone="success">connected</Badge>
          </div>

          <div class="flex items-center justify-between gap-4 border-b border-[var(--border-primary)] pb-3">
            <span class="font-mono-label text-[11px] uppercase tracking-[0.18em] text-[var(--text-muted)]">
              draft_and_send_logic
            </span>
            <Badge tone="blue">tested</Badge>
          </div>

          <div class="flex items-center justify-between gap-4">
            <span class="font-mono-label text-[11px] uppercase tracking-[0.18em] text-[var(--text-muted)]">
              mobile_polish_pass
            </span>
            <Badge tone="warm">in progress</Badge>
          </div>
        </div>

        <p class="mt-6 text-sm leading-7 text-[var(--text-muted)]">
          I’m using VoicePin to explore voice UX, short-form communication, audio permissions,
          async states, API boundaries, and the tiny details that make recording feel clear instead of stressful.
        </p>
      </Card>
    </div>
  </section>

  <section class="section-spacing mx-auto max-w-7xl px-5 md:px-8">
    <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
      <SectionHeading
        eyebrow="Selected work"
        title="Things I’m building"
        text="Projects built as learning artifacts — places to experiment, iterate, document decisions, and improve product quality over time."
      />

      <div class="mb-10">
        <ButtonLink href="/projects" variant="secondary">
          View all projects
        </ButtonLink>
      </div>
    </div>

    <div class="grid gap-5 lg:grid-cols-2">
      {
        projects.map((project) => (
          <ProjectCard project={project} />
        ))
      }
    </div>
  </section>

  <section class="section-spacing mx-auto max-w-7xl px-5 md:px-8">
    <SectionHeading
      eyebrow="Engineering signal"
      title="The portfolio should reflect curiosity, iteration, and engineering care — not only finished screenshots."
    />

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      <Card interactive>
        <h3 class="text-xl font-semibold text-[var(--text-primary)]">
          Product-minded frontend
        </h3>
        <p class="mt-4 text-base leading-[1.8] text-[var(--text-secondary)]">
          I like turning vague ideas into scoped MVPs with clear user flows, honest trade-offs,
          and enough structure to keep improving after the first version ships.
        </p>
      </Card>

      <Card interactive>
        <h3 class="text-xl font-semibold text-[var(--text-primary)]">
          Quality through behavior
        </h3>
        <p class="mt-4 text-base leading-[1.8] text-[var(--text-secondary)]">
          I use tests to describe important product behavior, edge cases, and regression-prone logic —
          not only to check that components render.
        </p>
      </Card>

      <Card interactive>
        <h3 class="text-xl font-semibold text-[var(--text-primary)]">
          User trust and care
        </h3>
        <p class="mt-4 text-base leading-[1.8] text-[var(--text-secondary)]">
          I care about accessibility, security, readable states, clear destructive actions,
          and interfaces that help users understand what is happening.
        </p>
      </Card>

      <Card interactive>
        <h3 class="text-xl font-semibold text-[var(--text-primary)]">
          Continuous iteration
        </h3>
        <p class="mt-4 text-base leading-[1.8] text-[var(--text-secondary)]">
          I enjoy improving products in passes: first make the flow work, then make it understandable,
          then make it resilient, then make it feel good.
        </p>
      </Card>
    </div>
  </section>

  <section class="section-spacing mx-auto max-w-7xl px-5 md:px-8">
    <Card>
      <div class="grid gap-8 md:grid-cols-[0.85fr_1.15fr] md:items-center">
        <div>
          <Badge tone="warm">About</Badge>

          <h2 class="mt-5 text-3xl font-semibold leading-tight tracking-[-0.04em] text-[var(--text-primary)] md:text-4xl">
            Microsoft-scale experience, indie-product ownership.
          </h2>
        </div>

        <div>
          <p class="text-base leading-[1.8] text-[var(--text-secondary)] md:text-lg">
            At Microsoft, I worked on frontend experiences across Skype and Teams. My side projects
            are where I practice end-to-end product ownership: idea, UX, architecture, testing,
            deployment, and documentation.
          </p>

          <p class="mt-5 text-base leading-[1.8] text-[var(--text-secondary)] md:text-lg">
            I care about interfaces that are understandable, accessible, secure, and thoughtfully made —
            the kind of products where engineering quality and user trust support each other.
          </p>

          <div class="mt-7">
            <ButtonLink href="/about" variant="secondary">
              Read more about how I work
            </ButtonLink>
          </div>
        </div>
      </div>
    </Card>
  </section>
</BaseLayout>