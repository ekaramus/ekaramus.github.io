---
import Badge from "../ui/Badge.astro";
import ButtonLink from "../ui/ButtonLink.astro";
import Card from "../ui/Card.astro";

import type { Project } from "../../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<Card interactive class="flex h-full flex-col">
  <div class="flex flex-1 flex-col">
    <div class="mb-6 flex items-start justify-between gap-4">
      <div>
        <Badge tone={project.featured ? "warm" : "blue"}>
          {project.status}
        </Badge>

        <h3 class="mt-5 text-2xl font-semibold tracking-[-0.04em] text-[var(--text-primary)]">
          {project.title}
        </h3>

        <p class="font-mono-label mt-2 text-[11px] uppercase tracking-[0.18em] text-[var(--text-muted)]">
          {project.type}
        </p>
      </div>

      <div
        aria-hidden="true"
        class="hidden h-16 w-16 rounded-[24px] border border-[var(--border-primary)] bg-[radial-gradient(circle_at_30%_20%,rgba(217,184,143,0.22),transparent_35%),radial-gradient(circle_at_70%_80%,rgba(91,164,255,0.16),transparent_38%),var(--bg-elevated)] md:block"
      >
      </div>
    </div>

    <p class="text-base leading-[1.8] text-[var(--text-secondary)]">
      {project.description}
    </p>

    <div class="mt-6 flex flex-wrap gap-2">
      {
        project.tags.map((tag) => (
          <Badge tone="default">
            {tag}
          </Badge>
        ))
      }
    </div>

    <div class="mt-7 border-t border-[var(--border-primary)] pt-6">
      <p class="font-mono-label mb-4 text-[11px] uppercase tracking-[0.18em] text-[var(--text-muted)]">
        Demonstrates
      </p>

      <ul class="space-y-3">
        {
          project.demonstrates.slice(0, 4).map((item) => (
            <li class="flex gap-3 text-sm leading-6 text-[var(--text-secondary)]">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--accent-warm)]"></span>
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="mt-8 flex flex-wrap gap-3">
      {
        project.links.map((link) =>
          link.disabled ? (
            <span class="font-mono-label inline-flex cursor-not-allowed items-center justify-center rounded-full border border-[var(--border-primary)] px-5 py-3 text-[12px] uppercase tracking-[0.18em] text-[var(--text-muted)] opacity-60">
              {link.label}
            </span>
          ) : (
            <ButtonLink
              href={link.href}
              external={link.external}
              variant={link.label === "Case study" ? "primary" : "secondary"}
            >
              {link.label}
            </ButtonLink>
          )
        )
      }
    </div>
  </div>
</Card>