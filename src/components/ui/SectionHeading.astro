---
interface Props {
  eyebrow: string;
  title: string;
  text?: string;
}

const { eyebrow, title, text } = Astro.props;
---

<div class="mb-12 max-w-3xl">
  <p class="font-mono-label mb-4 text-[12px] uppercase tracking-[0.16em] text-[var(--accent-warm)]">
    {eyebrow}
  </p>

  <h2 class="text-[clamp(2rem,4vw,2.75rem)] font-semibold leading-[1.08] tracking-[-0.04em] text-[var(--text-primary)]">
    {title}
  </h2>

  {
    text && (
      <p class="mt-6 max-w-[72ch] text-base leading-[1.8] text-[var(--text-secondary)] md:text-lg">
        {text}
      </p>
    )
  }
</div>