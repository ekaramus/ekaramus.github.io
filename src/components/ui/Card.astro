---
interface Props {
  class?: string;
  interactive?: boolean;
}

const {
  class: className = "",
  interactive = false,
} = Astro.props;
---

<div
  class:list={[
    "rounded-[24px] border border-[var(--border-primary)] bg-[rgba(17,24,39,0.82)] p-6 shadow-[var(--shadow-soft)] md:p-8",
    "transition duration-300",
    interactive &&
      "hover:-translate-y-1 hover:border-[var(--border-strong)] hover:bg-[rgba(26,34,53,0.9)]",
    className,
  ]}
>
  <slot />
</div>